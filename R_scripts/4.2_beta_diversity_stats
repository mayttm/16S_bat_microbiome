cat("\n\n")

# --- D. UNWEIGHTED UNIFRAC ANALYSIS ---
cat("D. UNWEIGHTED UNIFRAC (Phylogeny + Presence/Absence)\n")
cat("==========================================================\n\n")
cat("1. Homogeneity of Dispersion (PERMDISP):\n")
print(anova(betadisper(dist_uunifrac, metadata$Diet_type)))
