check_sample_coverage <- function(results) {
  
  all_indices <- results %>%
    pull(Sample_Indices) %>%
    str_split(";") %>%
    unlist() %>%
    unique() %>%
    sort()
  
  cat(sprintf("Total unique indices in results: %d\n", length(all_indices)))
  
  indices_by_family <- results %>%
    group_by(Family) %>%
    summarise(
      Indices = paste(unique(unlist(str_split(Sample_Indices, ";"))), collapse = ";"),
      Index_Count = n_distinct(unlist(str_split(Sample_Indices, ";")))
    ) %>%
    arrange(desc(Index_Count))
  
  cat("\nTop 10 families by number of samples (indices):\n")
  print(head(indices_by_family, 10))
  
  return(all_indices)
}

