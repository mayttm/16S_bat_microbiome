library(tidyverse)
library(stringr)

extract_taxonomic_info <- function(column_name) {
  if (!is.character(column_name)) {
    return(list(family = NA, genus = NA))
  }
  
  # Extract family
  family_match <- str_extract(column_name, "f__([^;]+)")
  family <- ifelse(!is.na(family_match), str_remove(family_match, "f__"), NA)
  
  # Extract genus
  genus_match <- str_extract(column_name, "g__([^;]+)")
  genus <- ifelse(!is.na(genus_match), str_remove(genus_match, "g__"), NA)
  
  return(list(family = family, genus = genus))
}

process_csv_file <- function(input_file, output_file) {
  # Read the CSV file
  df <- read_csv(input_file, show_col_types = FALSE)
  
  taxonomic_cols <- names(df)[grepl("^d__(Bacteria|Archaea);", names(df))]
  cat(sprintf("Found %d taxonomic columns\n", length(taxonomic_cols)))
  
  tax_info <- tibble(
    column = taxonomic_cols,
    family = sapply(taxonomic_cols, function(x) extract_taxonomic_info(x)$family),
    genus = sapply(taxonomic_cols, function(x) extract_taxonomic_info(x)$genus)
  ) %>%
    filter(!is.na(family) & !is.na(genus))
  
  # Reshape
  long_df <- df %>%
    select(index, Common.name_Species, Diet_type, all_of(tax_info$column)) %>%
    pivot_longer(
      cols = all_of(tax_info$column),
      names_to = "tax_column",
      values_to = "reads"
    ) %>%
    filter(reads > 0) %>%
    left_join(tax_info, by = c("tax_column" = "column")) %>%
    select(-tax_column)
  
  result <- long_df %>%
    group_by(Family = family, Animal = Common.name_Species, Genus = genus, Group = Diet_type) %>%
    summarise(
      Reads = sum(reads, na.rm = TRUE),
      Species = n_distinct(index),  
      Sample_Indices = paste(sort(unique(index)), collapse = ";"),  # All index names separated by ;
      .groups = "drop"
    ) %>%
    arrange(Family, Animal, desc(Reads))
  
  # Save results to CSV
  write_csv(result, output_file)
  cat(sprintf("Results saved to %s\n", output_file))
  
  cat(sprintf("Total unique families: %d\n", n_distinct(result$Family)))
  cat(sprintf("Total unique animals: %d\n", n_distinct(result$Animal)))
  cat(sprintf("Total unique genera: %d\n", n_distinct(result$Genus)))
  cat(sprintf("Total rows in output: %d\n", nrow(result)))
  cat(sprintf("Total samples (index values): %d\n", n_distinct(df$index)))
  
  diet_summary <- result %>%
    group_by(Group) %>%
    summarise(
      Total_Reads = sum(Reads),
      Unique_Families = n_distinct(Family),
      Total_Samples = n_distinct(unlist(str_split(Sample_Indices, ";")))
    )
  
  print(diet_summary)
  
  # Print top families
  top_families <- result %>%
    group_by(Family) %>%
    summarise(Total_Reads = sum(Reads)) %>%
    arrange(desc(Total_Reads)) %>%
    head(10)
  
  cat("\nTop 10 Families by Total Reads:\n")
  print(top_families)
  
  return(result)
}


