# REVISION 2: Updated the heatmap function.
# - use log1p() transformed data for the color scale.
# - (optional) displays the original, absolute numbers in the cells.
# - calculates and applies text color after clustering.
pheatmap_grob <- function(mat, title){
  # Use log1p transformation for color scaling. The original matrix 'mat' is for display.
  mat_log <- log1p(mat)
  
  # Run a preliminary pheatmap on the log-data to get the column clustering order
  p_temp <- pheatmap(mat_log, cluster_rows = FALSE, cluster_cols = TRUE, silent = TRUE)
  col_cluster <- p_temp$tree_col
  
  # To correctly color the numbers, we must create a color matrix that is
  # in the same final order as the clustered heatmap.
  mat_reordered_by_cols <- mat[, col_cluster$order]
  
  # Create the number color matrix based on the original data values
  number_colors_matrix <- ifelse(mat_reordered_by_cols > 1000, "black", "white")
  
  p <- pheatmap(mat_log, 
                color = viridis(100),
                cluster_rows = FALSE,
                cluster_cols = col_cluster, 
                annotation_col = animal_groups,
                annotation_colors = group_colors,
                main = title,
                fontsize = 10,
                angle_col = 45,
                display_numbers = FALSE, #change to mat to display the original raw counts
                number_format = "%.0f",
                number_color = number_colors_matrix, 
                border_color = "grey60",
                cellwidth = 40,
                cellheight = 20,
                silent = TRUE
  )
  
  # Extract gtable and add background (no changes here)
  gt <- p$gtable
  bg_rect <- rectGrob(gp = gpar(fill = "white", col = NA))
  final_grob <- gTree(children = gList(bg_rect, gt))
  return(final_grob)
}

