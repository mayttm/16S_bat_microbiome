plot_alpha_diet <- function(data, y_metric, title) {
  
  # 1. DEFINE ORDERED COMPARISONS
  # Get all unique groups and sort them alphabetically (or by factor level)
  groups <- sort(unique(as.character(data$Diet_type)))
  
  # Generate comparisons in the specific order:
  # (1 vs 2, 1 vs 3, 1 vs 4 ... then 2 vs 3, 2 vs 4 ... etc.)
  my_comparisons <- list()
  counter <- 1
  
  if(length(groups) > 1) {
    for(i in 1:(length(groups)-1)) {
      for(j in (i+1):length(groups)) {
        my_comparisons[[counter]] <- c(groups[i], groups[j])
        counter <- counter + 1
      }
    }
  }
  
  # 2. Calculate global p-value (Kruskal-Wallis)
  kruskal_p <- kruskal.test(as.formula(paste(y_metric, "~ Diet_type")), data = data)$p.value
  subtitle_text <- paste0("Kruskal-Wallis, p = ", sprintf("%.3f", kruskal_p))
  
  # 3. Plot Base
  p <- ggplot(data, aes(x = Diet_type, y = .data[[y_metric]], fill = Diet_type)) +
    geom_boxplot(alpha = 0.8, outlier.shape = NA) +
    geom_jitter(width = 0.1, size = 0.8, alpha = 0.4, color = "black") +
    theme_bw() +
    labs(title = title, subtitle = subtitle_text, x = "Diet Group", y = y_metric) +
    scale_fill_manual(values = diet_colors) +
    
    # --- LAYER A: NON-SIGNIFICANT (RED) ---
    stat_compare_means(
      comparisons = my_comparisons,
      method = "wilcox.test",
      label = "p.signif",
      step.increase = 0.05,    # Consistent step increase
      tip.length = 0.005,
      vjust = 0.5,  # vertical justification of asterisk or ns on the bracket
      color = "red",
      size = 3.5,
      symnum.args = list(
        cutpoints = c(0, 0.05, 1),
        symbols   = c("", "ns") # Hide significant, show ns
      )
    ) +
    
    # --- LAYER B: SIGNIFICANT (BLACK) ---
    stat_compare_means(
      comparisons = my_comparisons,
      method = "wilcox.test",
      label = "p.signif",
      step.increase = 0.05,    
      tip.length = 0.005,
      vjust = 0.5,
      color = "black",
      size = 4,
      symnum.args = list(
        cutpoints = c(0, 0.001, 0.01, 0.05, 1),
        symbols   = c("***", "**", "*", "") # Show stars, hide ns
      )
    ) +
    
    # Theme adjustments
    theme(
      legend.position = "none",
      plot.title = element_text(hjust = 0.5, face = "bold", size = 12),
      plot.subtitle = element_text(hjust = 0.5, size = 10, face = "italic"),
      axis.title.x = element_text(size = 10, face = "bold"),
      axis.title.y = element_text(size = 10, face = "bold"),
      axis.text.x = element_text(angle = 45, hjust = 1, vjust = 1, size = 10, color = "black"),
      axis.text.y = element_text(size = 10)
    )
  
  return(p)
}

