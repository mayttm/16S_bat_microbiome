  cat("Saved:", full_path, "\n")
}

# ------------------ 4. Sample-wise Correlation Analysis -----------------------

# Calculate Pearson correlation for each sample between the two methods
sample_cors <- sapply(1:ncol(mat_bp), function(i) {
  cor(mat_bp[, i], mat_pb[, i], method = "pearson")
})

summary_cors <- summary(sample_cors)
cat("\n--- Sample-wise Pearson Correlations ---\n")
print(summary_cors)

# Create a histogram of correlations for the manuscript
df_cor <- data.frame(Correlation = sample_cors)
p_hist <- ggplot(df_cor, aes(x = Correlation)) +
  geom_histogram(binwidth = 0.001, fill = "steelblue", color = "black") +
  theme_minimal() +
  labs(title = "Distribution of Sample-wise Correlations",
       subtitle = "Comparison of BioProject->Primer vs Primer->BioProject",
       x = "Pearson Correlation Coefficient (r)",
       y = "Count of Samples") +
  geom_vline(aes(xintercept = median(Correlation)), color="red", linetype="dashed")

ggsave(file.path(output_dir, "FigS6_Correlations_BP_vs_PB.jpg"), p_hist, width = 10, height = 8)

# ---- 5. Feature-wise Mean Difference (Bland-Altman style check) ----
# Calculate mean abundance per feature for both methods
mean_bp <- rowMeans(mat_bp)
mean_pb <- rowMeans(mat_pb)

# Calculate L2 norm (Euclidean distance) between the two full matrices
# A value close to 0 indicates identity
frobenius_diff <- norm(mat_bp - mat_pb, type = "F")
cat("\n--- Frobenius Norm of Difference Matrix (lower is better) ---\n")
print(frobenius_diff)

