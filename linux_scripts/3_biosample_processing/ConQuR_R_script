lvl <- intersect(names(diet2_colors), unique(as.character(pcoa_df$diet_2)))
pcoa_df$diet_2 <- factor(as.character(pcoa_df$diet_2), levels = lvl)

# Percent variance for axis labels (use only positive eigenvalues)
