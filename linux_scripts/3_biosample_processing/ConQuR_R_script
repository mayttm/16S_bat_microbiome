# 3) Beta diversity (Bray-Curtis on relative abundance) + PCoA + PERMANOVA
# Build X aligned to phy_copy and clamp negatives to 0 (if any)
X <- stages[[corrected_stage]][sample_names(phy_copy), taxa_names(phy_copy), drop = FALSE]
if (any(X < 0, na.rm = TRUE)) {
  warning("Negative values detected in corrected matrix; clamping to 0 for Bray-Curtis.")
  X[X < 0] <- 0
}

# Relative abundance transform
row_sums <- pmax(rowSums(X), 1e-8)
X_rel <- sweep(X, 1, row_sums, "/")

# Bray-Curtis distances
dist_bray <- vegan::vegdist(X_rel, method = "bray")

pcoa <- cmdscale(dist_bray, k = 2, eig = TRUE)
pcoa_df <- data.frame(SampleID = rownames(X_rel),
                      PC1 = pcoa$points[, 1],
                      PC2 = pcoa$points[, 2],
                      metadata_df[rownames(X_rel), , drop = FALSE],
                      check.names = FALSE)

# Use the distance labels (safer) for row order and metadata alignment
ord_samples <- labels(dist_bray)
meta_sub <- metadata_df[ord_samples, , drop = FALSE]
stopifnot(all(ord_samples == rownames(pcoa$points)))

# Build plotting frame
pcoa_df <- data.frame(
  SampleID = ord_samples,
  PC1 = pcoa$points[, 1],
  PC2 = pcoa$points[, 2],
  meta_sub,
  check.names = FALSE
)

# Ensure diet_2 exists and map colors properly
