missing_covars <- setdiff(covars, present_covars)
if (length(missing_covars) > 0) {
  warning("Missing covariates in metadata and will be ignored: ", paste(missing_covars, collapse = ", "))
}
covar <- meta[, present_covars, drop = FALSE]
covar[] <- lapply(covar, function(x) if (is.character(x)) factor(x) else x)

# ---- Helpers ----
pick_ref <- function(f) names(sort(table(f), decreasing = TRUE))[1]

# Defensive wrapper for ConQuR to avoid 'batchid not found' inside foreach body
run_conqur_once <- function(tax_tab, meta, batch_var, covar, batch_ref = NULL,
                            logistic_lasso = TRUE, quantile_type = "lasso", interplt = TRUE) {
  stopifnot(batch_var %in% colnames(meta))
  batch_vec <- factor(meta[[batch_var]])
  if (is.null(batch_ref)) batch_ref <- pick_ref(batch_vec)
  message(sprintf("ConQuR: correcting %s with reference level '%s'", batch_var, batch_ref))
  # Expose symbols some foreach bodies may look up non-locally
  assign("batchid", batch_vec, envir = .GlobalEnv)
  on.exit({ if (exists("batchid", envir = .GlobalEnv, inherits = FALSE)) rm("batchid", envir = .GlobalEnv) }, add = TRUE)
  assign("covariates", covar, envir = .GlobalEnv)
  on.exit({ if (exists("covariates", envir = .GlobalEnv, inherits = FALSE)) rm("covariates", envir = .GlobalEnv) }, add = TRUE)
  assign("tax_tab", tax_tab, envir = .GlobalEnv)
  on.exit({ if (exists("tax_tab", envir = .GlobalEnv, inherits = FALSE)) rm("tax_tab", envir = .GlobalEnv) }, add = TRUE)
  ConQuR(
    tax_tab        = tax_tab,
    batchid        = batch_vec,
    covariates     = covar,
    batch_ref      = batch_ref,
    logistic_lasso = logistic_lasso,
    quantile_type  = quantile_type,
    interplt       = interplt
  )
}

# ---- IMPORTANT: stay sequential; do NOT create or register any parallel clusters ----

# ---- Sequential corrections ----
# A) bioproject -> primer_group
