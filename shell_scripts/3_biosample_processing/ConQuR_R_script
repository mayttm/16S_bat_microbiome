df_bp <- data.frame(feature_id = rownames(taxa_corrected_bio_primer), taxa_corrected_bio_primer, check.names = FALSE)
otu_path_bp <- file.path(output_dir, "otu_table_corrected_bioproject_then_primer_group.txt")
write.table(df_bp, file = otu_path_bp, sep = "\t", quote = FALSE, row.names = FALSE, col.names = TRUE)
cat("Batch-corrected OTU table written to:", otu_path_bp, "\n")

