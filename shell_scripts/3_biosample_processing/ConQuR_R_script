# ---- Output directory ----
output_dir <- "conqur/160_comb_diet2_20260312"
dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)

# ---- Inputs ----
tab_qza_filename  <- "step.02.c.deblur.table-filtered.qza"
metadata_filename <- "metadata_160_20250905.txt"
tree_qza_filename <- "tree.rooted.qza"

# ---- Import ----
phy <- qza_to_phyloseq(
  features = tab_qza_filename,
  metadata = metadata_filename,
  tree     = tree_qza_filename,
  tmp      = "tmp"
)

# ---- Matrices & metadata ----
taxa <- as(otu_table(phy), "matrix")
if (taxa_are_rows(phy)) taxa <- t(taxa)  # ensure rows = samples, cols = features
meta <- data.frame(as(sample_data(phy), "data.frame"), check.names = FALSE, stringsAsFactors = FALSE)

# Keep only non-empty samples present in metadata
keep_samples <- rowSums(taxa) > 0
taxa <- taxa[keep_samples, , drop = FALSE]
meta  <- meta[rownames(taxa), , drop = FALSE]

# Ensure primer_group has consistent levels (after subsetting meta)
if ("primer_group" %in% names(meta)) {
  meta$primer_group <- factor(
    meta$primer_group,
    levels = c("V4_1", "V4_2", "V3-V4_1", "V3-V4_2", "V3-V4_4", "V3-V4_5")
  )
}

# ---- Covariates to preserve (robust selection) ----
covars <- c("sample_type", "diet_2", "roost_group", "captive_wild", "habitat_level_1")
present_covars <- intersect(covars, colnames(meta))
missing_covars <- setdiff(covars, present_covars)
if (length(missing_covars) > 0) {
  warning("Missing covariates in metadata and will be ignored: ", paste(missing_covars, collapse = ", "))
}
covar <- meta[, present_covars, drop = FALSE]
covar[] <- lapply(covar, function(x) if (is.character(x)) factor(x) else x)

# ---- Helpers ----
pick_ref <- function(f) names(sort(table(f), decreasing = TRUE))[1]

# Defensive wrapper for ConQuR to avoid 'batchid not found' inside foreach body
run_conqur_once <- function(tax_tab, meta, batch_var, covar, batch_ref = NULL,
                            logistic_lasso = TRUE, quantile_type = "lasso", interplt = TRUE) {
  stopifnot(batch_var %in% colnames(meta))
  batch_vec <- factor(meta[[batch_var]])
  if (is.null(batch_ref)) batch_ref <- pick_ref(batch_vec)
  message(sprintf("ConQuR: correcting %s with reference level '%s'", batch_var, batch_ref))
  # Expose symbols some foreach bodies may look up non-locally
  assign("batchid", batch_vec, envir = .GlobalEnv)
  on.exit({ if (exists("batchid", envir = .GlobalEnv, inherits = FALSE)) rm("batchid", envir = .GlobalEnv) }, add = TRUE)
  assign("covariates", covar, envir = .GlobalEnv)
  on.exit({ if (exists("covariates", envir = .GlobalEnv, inherits = FALSE)) rm("covariates", envir = .GlobalEnv) }, add = TRUE)
  assign("tax_tab", tax_tab, envir = .GlobalEnv)
  on.exit({ if (exists("tax_tab", envir = .GlobalEnv, inherits = FALSE)) rm("tax_tab", envir = .GlobalEnv) }, add = TRUE)
  ConQuR(
    tax_tab        = tax_tab,
    batchid        = batch_vec,
    covariates     = covar,
    batch_ref      = batch_ref,
    logistic_lasso = logistic_lasso,
    quantile_type  = quantile_type,
    interplt       = interplt
  )
}

# ---- IMPORTANT: stay sequential; do NOT create or register any parallel clusters ----

# ---- Sequential corrections ----
# A) bioproject -> primer_group
bio1 <- run_conqur_once(taxa, meta, batch_var = "bioproject",   covar = covar)
bio_then_primer <- run_conqur_once(bio1,  meta, batch_var = "primer_group", covar = covar)

# B) primer_group -> bioproject
pri1 <- run_conqur_once(taxa, meta, batch_var = "primer_group", covar = covar)
primer_then_bio <- run_conqur_once(pri1,  meta, batch_var = "bioproject",   covar = covar)

# Also keep single-source corrections if comparison is needed
bio_only    <- bio1
primer_only <- pri1

# Collect stages
stages <- list(
  raw                 = taxa,
  bio_only            = bio_only,
  primer_only         = primer_only,
  bio_then_primer     = bio_then_primer,
  primer_then_bio     = primer_then_bio
)

# ---- Save corrected matrices (RDS + TSV.GZ for each stage) ----
saveRDS(stages, file = file.path(output_dir, "taxa_stages.rds"))
for (nm in names(stages)) {
  fn <- file.path(output_dir, paste0("taxa_", nm, ".tsv.gz"))
  write.table(stages[[nm]], file = gzfile(fn), sep = "\t", quote = FALSE, col.names = NA)
}

# ---- Export batch-corrected OTU tables as .txt ----
